{#
/**
 * @file
 * Default theme implementation for the Performance Dashboard block.
 *
 * Available variables:
 * - metrics: Dashboard metrics data.
 * - chart_data: Chart data for Google Charts.
 * - action_report: Action report items.
 * - users_report: Users report data.
 */
#}
<div class="performance-dashboard">
  <div class="dashboard-container">
    
    {# Header with Filter #}
    {% set program_id_suffix = program_id is defined ? '_' ~ program_id : '' %}
    <div class="dashboard-header">
      <h2 class="dashboard-title">Performance Dashboard</h2>
      <div class="dashboard-filters">
        <button type="button" class="btn-date-range" id="dateRangeToggle{{ program_id_suffix }}" data-program-id="{{ program_id }}">
          <span>Date Range</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256">
            <path d="M213.66,101.66l-80,80a8,8,0,0,1-11.32,0l-80-80A8,8,0,0,1,53.66,90.34L128,164.69l74.34-74.35a8,8,0,0,1,11.32,11.32Z"/>
          </svg>
        </button>
      </div>
    </div>

    {# Date Range Row (Hidden by default) #}
    <div id="dateRangeRow{{ program_id_suffix }}" class="date-range-row" style="display: none;" data-program-id="{{ program_id }}">
      <div class="date-input-group">
        <label>From Date:</label>
        <input type="date" class="date-from-input" id="dateFrom{{ program_id_suffix }}" name="from_date">
      </div>
      <div class="date-input-group">
        <label>To Date:</label>
        <input type="date" class="date-to-input" id="dateTo{{ program_id_suffix }}" name="to_date">
      </div>
      <div class="date-actions">
        <button type="button" class="btn-primary date-submit-btn" data-program-id="{{ program_id }}">Submit</button>
        <button type="button" class="btn-secondary date-reset-btn" data-program-id="{{ program_id }}">Reset</button>
      </div>
    </div>

    {# Metric Cards #}
    <div class="metrics-grid">
      <div class="metric-card">
        <p class="metric-label">Number of Users Coached</p>
        <div class="metric-value">{{ metrics.users_coached.value }}</div>
        <p class="metric-change positive">{{ metrics.users_coached.change }}</p>
      </div>

      <div class="metric-card">
        <p class="metric-label">Coaching Sessions</p>
        <div class="metric-value">{{ metrics.coaching_sessions.value }}</div>
        <p class="metric-change positive">{{ metrics.coaching_sessions.change }}</p>
      </div>

      <div class="metric-card">
        <p class="metric-label">Behavioral Progress</p>
        <div class="metric-value">{{ metrics.behavioral_progress.value }}</div>
        <p class="metric-change positive">{{ metrics.behavioral_progress.change }}</p>
      </div>

      <div class="metric-card">
        <p class="metric-label">On the Job Progress</p>
        <div class="metric-value">{{ metrics.on_job_progress.value }}</div>
        <p class="metric-change positive">{{ metrics.on_job_progress.change }}</p>
      </div>

      <div class="metric-card">
        <p class="metric-label">ROI</p>
        <div class="metric-value">{{ metrics.roi.value }}</div>
        <p class="metric-change positive">{{ metrics.roi.change }}</p>
      </div>
    </div>

    {# Chart Cards #}
    {% set chart_id_suffix = program_id is defined ? '_' ~ program_id : '' %}
    <div class="charts-section">
      <div class="chart-row">
        <div class="chart-card">
          <h5>Overview of Coaching Results</h5>
          <div id="overviewChart{{ chart_id_suffix }}" class="chart-container" data-chart-type="overview"></div>
        </div>

        <div class="chart-card">
          <h5>Competency Trends</h5>
          <div id="competencyChart{{ chart_id_suffix }}" class="chart-container" data-chart-type="competency"></div>
        </div>
      </div>

      <div class="chart-row">
        <div class="chart-card">
          <h5>Stars, Core and Laggards</h5>
          <div id="departmentChart{{ chart_id_suffix }}" class="chart-container" data-chart-type="department"></div>
        </div>

        <div class="chart-card">
          <h5>Coaching Sessions</h5>
          <div id="sessionsChart{{ chart_id_suffix }}" class="chart-container" data-chart-type="sessions"></div>
        </div>
      </div>
    </div>

    {# Action Report #}
    <div class="report-section">
      <h3 class="section-title">Action Report</h3>
      <div class="search-bar">
        <span class="search-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256">
            <path d="M229.66,218.34l-50.07-50.06a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"/>
          </svg>
        </span>
        <input type="text" placeholder="Search competencies" class="search-input">
      </div>

      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>Competencies</th>
              <th>Status</th>
              <th>Due Date</th>
              <th>Progress</th>
            </tr>
          </thead>
          <tbody>
            {% for item in action_report %}
              <tr>
                <td>{{ item.competency }}</td>
                <td>
                  {% set status_class = '' %}
                  {% if item.status == 'Completed' %}
                    {% set status_class = 'status-completed' %}
                  {% elseif item.status == 'In Progress' %}
                    {% set status_class = 'status-in-progress' %}
                  {% elseif item.status == 'Not Started' %}
                    {% set status_class = 'status-not-started' %}
                  {% endif %}
                  <span class="badge {{ status_class }}">{{ item.status }}</span>
                </td>
                <td>{{ item.due_date }}</td>
                <td>
                  <div class="progress-container">
                    <div class="progress-bar">
                      <div class="progress-fill" style="width: {{ item.progress }}%"></div>
                    </div>
                    <span class="progress-value">{{ item.progress }}</span>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    {# Users Report #}
    <div class="report-section">
      <h3 class="section-title">Users Report</h3>
      <div class="search-bar">
        <span class="search-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256">
            <path d="M229.66,218.34l-50.07-50.06a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"/>
          </svg>
        </span>
        <input type="text" placeholder="Search users" class="search-input">
      </div>

      <div class="table-container">
        <table class="data-table users-table">
          <thead>
            <tr>
              <th>Number</th>
              <th>Name</th>
              <th>Comparison</th>
              <th>Coach</th>
              <th>Latest Performance</th>
              <th>Previous Performance</th>
              <th>Next Session</th>
              <th>Last Session</th>
              <th>First Session</th>
            </tr>
          </thead>
          <tbody class="users-report-tbody">
            {% if users_report.data is defined %}
              {% for user in users_report.data %}
                <tr>
                  <td>{{ user.number }}</td>
                  <td>{{ user.name }}</td>
                  <td>{{ user.comparison }}</td>
                  <td>{{ user.coach }}</td>
                  <td>
                    <div class="progress-container">
                      <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ user.latest_performance }}%"></div>
                      </div>
                      <span class="progress-value">{{ user.latest_performance }}</span>
                    </div>
                  </td>
                  <td>
                    <div class="progress-container">
                      <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ user.previous_performance }}%"></div>
                      </div>
                      <span class="progress-value">{{ user.previous_performance }}</span>
                    </div>
                  </td>
                  <td>{{ user.next_session }}</td>
                  <td>{{ user.last_session }}</td>
                  <td>{{ user.first_session }}</td>
                </tr>
              {% endfor %}
            {% else %}
              {% for user in users_report %}
                <tr>
                  <td>{{ user.number }}</td>
                  <td>{{ user.name }}</td>
                  <td>{{ user.comparison }}</td>
                  <td>{{ user.coach }}</td>
                  <td>
                    <div class="progress-container">
                      <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ user.latest_performance }}%"></div>
                      </div>
                      <span class="progress-value">{{ user.latest_performance }}</span>
                    </div>
                  </td>
                  <td>
                    <div class="progress-container">
                      <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ user.previous_performance }}%"></div>
                      </div>
                      <span class="progress-value">{{ user.previous_performance }}</span>
                    </div>
                  </td>
                  <td>{{ user.next_session }}</td>
                  <td>{{ user.last_session }}</td>
                  <td>{{ user.first_session }}</td>
                </tr>
              {% endfor %}
            {% endif %}
          </tbody>
        </table>
      </div>

      {# Dynamic Pagination #}
      {% if users_report.pagination is defined %}
        {% set pagination = users_report.pagination %}
        <div class="pagination">
          <nav>
            <ul class="pagination-list">
              {# Previous Button #}
              <li class="page-item {% if pagination.current_page == 0 %}disabled{% endif %}">
                <a class="page-link pagination-link" 
                   href="#" 
                   data-page="{{ pagination.current_page - 1 }}" 
                   aria-label="Previous">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="24" fill="currentColor" viewBox="0 0 256 256">
                    <path d="M165.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L91.31,128Z"/>
                  </svg>
                </a>
              </li>
              
              {# Page Numbers #}
              {% for page_num in 0..pagination.total_pages - 1 %}
                <li class="page-item {% if page_num == pagination.current_page %}active{% endif %}">
                  <a class="page-link pagination-link" 
                     href="#" 
                     data-page="{{ page_num }}">
                    {{ page_num + 1 }}
                  </a>
                </li>
              {% endfor %}
              
              {# Next Button #}
              <li class="page-item {% if pagination.current_page >= pagination.total_pages - 1 %}disabled{% endif %}">
                <a class="page-link pagination-link" 
                   href="#" 
                   data-page="{{ pagination.current_page + 1 }}" 
                   aria-label="Next">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="24" fill="currentColor" viewBox="0 0 256 256">
                    <path d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L164.69,128,90.34,53.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z"/>
                  </svg>
                </a>
              </li>
            </ul>
          </nav>
        </div>
      {% endif %}
    </div>

  </div>
</div>

{# Pass chart data to JavaScript using drupalSettings #}
{% if program_id is defined %}
<script>
  (function() {
    if (typeof Drupal !== 'undefined' && typeof drupalSettings !== 'undefined') {
      // Initialize structure
      drupalSettings.performanceDashboard = drupalSettings.performanceDashboard || {};
      drupalSettings.performanceDashboard.programs = drupalSettings.performanceDashboard.programs || {};
      
      // Store chart data for this program
      drupalSettings.performanceDashboard.programs['{{ program_id }}'] = {{ chart_data|json_encode|raw }};
      
      {% if debug is defined %}
      // Store debug information
      drupalSettings.performanceDashboard.programs['{{ program_id }}'].debug = {{ debug|json_encode|raw }};
      {% endif %}
      
      // Legacy support (keep Drupal.settings for compatibility)
      Drupal.settings = Drupal.settings || {};
      Drupal.settings.performanceDashboard = Drupal.settings.performanceDashboard || {};
      Drupal.settings.performanceDashboard.programs = Drupal.settings.performanceDashboard.programs || {};
      Drupal.settings.performanceDashboard.programs['{{ program_id }}'] = {{ chart_data|json_encode|raw }};
      
      // Debug: Log chart data for this program
      console.log('✅ Chart data loaded for program {{ program_id }}:', drupalSettings.performanceDashboard.programs['{{ program_id }}']);
      console.log('  - Overview data points:', drupalSettings.performanceDashboard.programs['{{ program_id }}'].overview?.length || 0);
      console.log('  - Competency data points:', drupalSettings.performanceDashboard.programs['{{ program_id }}'].competency?.length || 0);
      console.log('  - Department data points:', drupalSettings.performanceDashboard.programs['{{ program_id }}'].department?.length || 0);
      console.log('  - Sessions data points:', drupalSettings.performanceDashboard.programs['{{ program_id }}'].sessions?.length || 0);
      
      {% if debug is defined %}
      // Debug: SQL Query Parameters
      console.log('\n🔍 DEBUG INFO FOR PROGRAM {{ program_id }}:');
      console.log('=====================================');
      console.log('📋 Parameters:', drupalSettings.performanceDashboard.programs['{{ program_id }}'].debug.parameters);
      console.log('📅 Date Range:', drupalSettings.performanceDashboard.programs['{{ program_id }}'].debug.date_range_calculated);
      console.log('=====================================\n');
      console.log('💡 To see SQL queries, check Drupal logs:');
      console.log('   ddev drush watchdog:show --type=coach_reporting_system --count=20');
      console.log('=====================================\n');
      {% endif %}
    } else {
      console.error('❌ Drupal or drupalSettings not available!');
    }
  })();
</script>
{% else %}
<script>
  if (typeof Drupal !== 'undefined' && typeof drupalSettings !== 'undefined') {
    // Initialize structure
    drupalSettings.performanceDashboard = drupalSettings.performanceDashboard || {};
    drupalSettings.performanceDashboard.chartData = {{ chart_data|json_encode|raw }};
    
    // Legacy support
    Drupal.settings = Drupal.settings || {};
    Drupal.settings.performanceDashboard = Drupal.settings.performanceDashboard || {};
    Drupal.settings.performanceDashboard.chartData = {{ chart_data|json_encode|raw }};
    
    // Debug: Log chart data
    console.log('✅ Chart data loaded (single):', drupalSettings.performanceDashboard.chartData);
  } else {
    console.error('❌ Drupal or drupalSettings not available!');
  }
</script>
{% endif %}

