      'variables' => [
        'employee_details' => NULL,
        'tabs' => NULL,
        'no_tabs' => NULL,
      ],
      'template' => 'report-result-tabs',
    ],
    'report_result' => [
      'variables' => [
        'employee_details' => NULL,
        'per_person_report' => NULL,
        'competency_analysis' => NULL,
        'on_job_performance' => NULL,
        'coaching_impact' => NULL,
        'one_to_one_coaching' => NULL,
      ],
      'template' => 'report-result',
    ],
    'per_person_report' => [
      'variables' => [
        'table' => NULL,
      ],
      'template' => 'per-person-report',
    ],
    'performance_dashboard' => [
      'variables' => [
        'metrics' => NULL,
        'chart_data' => NULL,
        'action_report' => NULL,
        'users_report' => NULL,
      ],
      'template' => 'performance-dashboard',
    ],
    'performance_dashboard_accordion' => [
      'variables' => [
        'companies' => NULL,
        'coaches' => NULL,
        'selected_company' => NULL,
        'selected_coach' => NULL,
        'is_company' => FALSE,
        'company_name' => NULL,
        'coach_name' => NULL,
        'report_type' => NULL,
        'from_date' => NULL,
        'to_date' => NULL,
        'show_results' => FALSE,
        'accordion_items' => NULL,
      ],
      'template' => 'performance-dashboard-accordion',
    ],
  ];
}
